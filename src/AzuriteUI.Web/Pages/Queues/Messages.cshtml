@page "{queueName}"
@model AzuriteUI.Web.Pages.Queues.MessagesModel
@{
    ViewData["Title"] = $"Queue: {Model.QueueName} Messages";
}

<h2>Messages in Queue: @Model.QueueName</h2>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-success">@Model.StatusMessage</div>
}


<div class="mb-3">
    <form method="post" asp-page-handler="Create" class="form-inline" style="display:inline-block; margin-right:8px;">
        <input type="hidden" name="QueueName" value="@Model.QueueName" />
        <div class="input-group">
            <input class="form-control" name="NewMessageText" placeholder="Message text" />
            <button class="btn btn-primary" type="submit">Create Message</button>
        </div>
    </form>
    <form method="post" asp-page-handler="CreateQueue" class="form-inline" style="display:inline-block;">
        <div class="input-group">
            <input 
                class="form-control" 
                name="NewQueueName" 
                id="queuePageNewQueueName" 
                placeholder="New queue name" 
                maxlength="63"
                pattern="^[a-z0-9]+((-[a-z0-9]+)*)$"
                title="Queue name must be 3-63 chars, lowercase letters, numbers, and dashes, no consecutive dashes, cannot start/end with dash"
                minlength="3"
                required />
            <button class="btn btn-success" type="submit">Create Queue</button>
        </div>
    </form>
    <div class="text-muted small mt-1">
        Queue name must be 3-63 chars, lowercase letters, numbers, and dashes, no consecutive dashes, cannot start/end with dash.
    </div>
</div>

<div class="mb-3">
    <form method="post" asp-page-handler="Dequeue" style="display:inline-block; margin-right:8px;">
        <input type="hidden" name="QueueName" value="@Model.QueueName" />
        <button class="btn btn-warning" type="submit">Dequeue One</button>
    </form>
    <form method="post" asp-page-handler="ClearQueue" style="display:inline-block; margin-right:8px;">
        <input type="hidden" name="QueueName" value="@Model.QueueName" />
        <button class="btn btn-danger" type="submit">Clear Queue</button>
    </form>
    <form method="post" asp-page-handler="DeleteQueue" style="display:inline-block;">
        <input type="hidden" name="QueueName" value="@Model.QueueName" />
        <button class="btn btn-danger" type="submit">Delete Queue</button>
    </form>
</div>

@if (Model.DecodedMessages != null && Model.DecodedMessages.Any())
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Message ID</th>
                <th>Text</th>
                <th>Insertion Time</th>
                <th>Expiration Time</th>
                <th>Next Visible Time</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var msg in Model.DecodedMessages)
        {
            <tr>
                <td>@msg.Message.MessageId</td>
                <td style="max-width: 40vw;overflow: auto;">@msg.DecodedText</td>
                <td>@msg.Message.InsertedOn</td>
                <td>@msg.Message.ExpiresOn</td>
                <td></td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">No messages found in this queue.</div>
}
